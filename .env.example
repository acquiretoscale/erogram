# Copy this file to .env.local and fill in values.
# Get production values from Vercel: Project → Settings → Environment Variables.
# Without MONGODB_URI, every page will fail to render (404-like behavior locally).

# Required for all server-rendered pages and API routes (no DB = all pages fail).
# Only MONGODB_URI is used (Atlas recommended). No other MongoDB env vars.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/yourdb

# Optional (have defaults)
NEXT_PUBLIC_SITE_URL=https://erogram.pro
JWT_SECRET=your-secret

# R2 / images (optional for local dev; uploads may fail without them)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=erogramimages
# R2_PUBLIC_URL=

# Optional: placeholder image when no image is set or upload fails (SEO-friendly).
# After uploading: node --env-file=.env.local scripts/upload-placeholder-to-r2.mjs
# Then set NEXT_PUBLIC_PLACEHOLDER_IMAGE_URL to the printed R2 URL (e.g. https://pub-xxx.r2.dev/placeholders/no-image.png)
# NEXT_PUBLIC_PLACEHOLDER_IMAGE_URL=

# Advertise page: password for the media kit gate (shared with advertisers). Default: erogram2026
# ADVERTISE_PASSWORD=erogram2026

# Advertise page: optional. Public URL of TGempire dashboard (e.g. https://tgempire.vercel.app) to show live Telegram channel subscriber counts on /advertise.
# TGEMPIRE_PUBLIC_URL=https://your-tgempire-domain.com

# Advertise page mailto form – address is loaded at runtime from API (not in HTML/JS bundle). /api is disallowed in robots.txt so it is not indexed.
# CONTACT_EMAIL=your@email.com

# Telegram (optional for local)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=

# Telegram Stars payments — REQUIRED for premium subscriptions.
# This MUST be a bot YOU own (created via @BotFather on YOUR Telegram account).
# Money from Stars goes to the owner of this bot. No fallback — payments are
# disabled if this variable is missing, to prevent routing money to a wrong account.
# TELEGRAM_PAYMENT_BOT_TOKEN=

# Webhook secret — REQUIRED to secure the payment webhook.
# Prevents anyone from sending fake payment events to your server.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# After setting this, re-run: npx tsx scripts/setup-payment-webhook.ts
# TELEGRAM_WEBHOOK_SECRET=
