# ──────────────────────────────────────────────────────────────
# TGempire — Environment Variables
# Copy this to .env.local and fill in real values
# ──────────────────────────────────────────────────────────────

# Admin login password (used as seed password for first owner account)
ADMIN_PASSWORD=change_me
# Secret for signing session cookies (generate a random string)
AUTH_SECRET=change_me_random_secret

# ── TELEGRAM ──────────────────────────────────────────────────
# Main bot token (EroGroupManager — used for posting to adult channels)
TELEGRAM_BOT_TOKEN=

# Erogram.pro notification bot (posts to @erogrampro when groups/bots are approved)
EROGRAM_NOTIFY_BOT_TOKEN=
# Erogram Plus VIP bot + channel
EROGRAM_PLUS_BOT_TOKEN=
EROGRAM_PLUS_CHANNEL_ID=

# TalkWithaStrangerBot (Omegle-like random chat)
TALKSTRANGER_BOT_TOKEN=
# Plus18ConfessionsBot (confession moderation)
CONFESSION_BOT_TOKEN=

# ── MONGODB ───────────────────────────────────────────────────
# TGempire's own database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tg-manager

# Erogram.pro website database (read-only, for Ecosystem KPIs)
EROGRAM_MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/erogram

# ── CLOUDFLARE R2 (media storage) ────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
# Namespace prefix inside the shared bucket. Set empty when TGempire has its own bucket.
R2_NAMESPACE=tgempire

# ── ALERTS ────────────────────────────────────────────────────
# Your personal Telegram chat ID for error notifications (get from @userinfobot)
ALERT_CHAT_ID=

# ── CLICK TRACKING ────────────────────────────────────────────
# Base URL for tracking redirects (e.g. https://tgempire.erogram.pro)
TRACKING_BASE_URL=

# ── VERCEL CRON ───────────────────────────────────────────────
# Secret for authenticating cron job requests (set in Vercel dashboard)
CRON_SECRET=
